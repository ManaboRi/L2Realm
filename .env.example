# ─── Копировать в .env на сервере ───
# Пароль PostgreSQL (придумай надёжный)
POSTGRES_PASSWORD=change-me-strong-password

# JWT секрет (придумай длинную случайную строку — 32+ символов)
JWT_SECRET=change-me-very-long-random-string-at-least-32-chars

# Для CORS backend. После деплоя указать реальный домен.
FRONTEND_URL=https://www.l2realm.ru,https://l2realm.ru
