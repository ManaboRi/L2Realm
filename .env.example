# ─── Копировать в /opt/l2realm/.env на VPS (рядом с docker-compose.yml) ───
# Этот файл читает docker compose и пробрасывает переменные в контейнеры
# через блок environment: в docker-compose.yml.

# Пароль PostgreSQL (придумай надёжный)
POSTGRES_PASSWORD=change-me-strong-password

# JWT секрет — >=32 символа, backend падает при старте если короче.
# Сгенерировать: openssl rand -base64 48
JWT_SECRET=change-me-very-long-random-string-at-least-32-chars

# CORS backend. После деплоя указать реальный домен.
FRONTEND_URL=https://www.l2realm.ru,https://l2realm.ru

# Доступ в админку (вход по email+паролю, публичной регистрации нет).
# Используется сидом для создания учётки администратора.
ADMIN_EMAIL=admin@l2realm.ru
ADMIN_PASS=change-me-strong-admin-password

# Секретный ключ для входа в админку по файлу-ярлыку (на ПК админа).
# Открываешь l2realm-admin.url → автlogин. >=32 символа.
# Генерация: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_KEY=change-me-long-random-admin-key-at-least-32-chars
