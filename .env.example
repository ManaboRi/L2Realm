# ─── Копировать в /opt/l2realm/.env на VPS (рядом с docker-compose.yml) ───
# Этот файл читает docker compose и пробрасывает переменные в контейнеры
# через блок environment: в docker-compose.yml.

# Пароль PostgreSQL (придумай надёжный)
POSTGRES_PASSWORD=change-me-strong-password

# JWT секрет — >=32 символа, backend падает при старте если короче.
# Сгенерировать: openssl rand -base64 48
JWT_SECRET=change-me-very-long-random-string-at-least-32-chars

# CORS backend. После деплоя указать реальный домен.
FRONTEND_URL=https://www.l2realm.ru,https://l2realm.ru

# VK ID (https://id.vk.com)
VK_CLIENT_ID=
VK_CLIENT_SECRET=
VK_REDIRECT_URI=https://l2realm.ru/auth/callback
VK_PIXEL_ID=

# ЮКасса (https://yookassa.ru → Настройки → API-ключи)
# В dev можно не задавать — backend активирует покупки сразу (dev mode).
# В production без них backend откажется создавать платёж.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
