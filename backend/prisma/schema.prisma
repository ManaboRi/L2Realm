// ══════════════════════════════════════════════
// L2Realm — Prisma Schema
// База данных: PostgreSQL
// ══════════════════════════════════════════════

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Пользователи ──────────────────────────────
model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  password           String?
  name               String?
  nickname           String?   @unique
  avatar             String?
  role               Role      @default(USER)
  emailVerified      Boolean   @default(false)
  emailCode          String?
  emailCodeExpires   DateTime?
  resetToken         String?
  resetTokenExpires  DateTime?
  registrationIp     String?
  vkId               String?   @unique
  nicknameChangedAt  DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  reviews        Review[]
  favorites      Favorite[]
  openingReminders OpeningReminder[]
  serverRequests ServerRequest[]
  votes          Vote[]
}

enum Role {
  USER
  ADMIN
}

// ── Серверы ───────────────────────────────────
model Server {
  id          String   @id
  name        String
  abbr        String?
  url         String
  chronicle   String
  rates       String
  rateNum     Int      @default(1)
  donate      String   @default("cosmetic") // cosmetic | convenience | p2w
  type        String[] // pvp | pve | pvp-pve | gve | rvr | multiproff | multicraft | new | featured
  vip         Boolean  @default(false)
  openedDate  DateTime?
  country     String   @default("RU")
  icon        String?
  banner      String?
  discord     String?
  telegram    String?
  vk          String?
  youtube     String?
  site        String?
  clientUrl   String?
  patchUrl    String?
  updaterUrl  String?
  downloadLinks Json    @default("[]")
  installGuide String?
  fullDesc    String?
  rating       Float    @default(0)
  ratingCount  Int      @default(0)
  totalVotes   Int      @default(0)
  monthlyVotes Int      @default(0)
  weeklyVotes  Int      @default(0)
  voteRewardsEnabled Boolean @default(false)
  manualCheckAt DateTime?
  trustLevel   String?
  activityLevel String?
  status      String   @default("online") // online | offline | unknown
  statusOverride String? // null/auto = мониторинг, online/offline/unknown = ручной статус
  trafficMonthly Int?
  trafficThreeMonths Int?
  trafficPeriod String?
  trafficSource String?
  trafficHistory Json @default("[]")
  // Внутренние «запуски» проекта (Scryde-кейс). Каждый — карточка
  // с рейтом/хроникой/URL внешнего сайта. Без своих ID, отзывов, голосов.
  // [{ id, label?, chronicle, rates, rateNum, type?, donate?, url, openedDate?, lifecycleStatus? }]
  instances    Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reviews      Review[]
  subscription Subscription?
  news         News[]
  monitorLogs  MonitorLog[]
  favorites    Favorite[]
  openingReminders OpeningReminder[]
  openingWaits OpeningWait[]
  openingClicks OpeningClick[]
  boosts       Boost[]
  votes        Vote[]
}

// ── Избранное / Watchlist ─────────────────────
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  serverId  String
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, serverId])
  @@index([userId])
}

model OpeningReminder {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  serverId   String
  server     Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  instanceId String    @default("")
  openingAt  DateTime
  notifyAt   DateTime
  notifiedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([userId, serverId, instanceId])
  @@index([userId, notifyAt])
  @@index([notifyAt, notifiedAt])
}

model OpeningWait {
  id         String   @id @default(cuid())
  serverId   String
  server     Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  instanceId String   @default("")
  ipHash     String
  weekKey    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([serverId, instanceId, ipHash, weekKey])
  @@index([serverId, instanceId, weekKey])
  @@index([weekKey, createdAt])
  @@index([ipHash, weekKey])
}

model OpeningClick {
  id         String   @id @default(cuid())
  serverId   String
  server     Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  instanceId String   @default("")
  ipHash     String
  userAgent  String?
  referer     String?
  targetUrl  String
  source     String   @default("coming-soon")
  createdAt  DateTime @default(now())

  @@index([serverId, instanceId, createdAt])
  @@index([createdAt])
  @@index([ipHash, createdAt])
}

// ── Подписки / Тарифы ─────────────────────────
model Subscription {
  id         String           @id @default(cuid())
  serverId   String           @unique
  server     Server           @relation(fields: [serverId], references: [id], onDelete: Cascade)
  plan       SubscriptionPlan @default(FREE)
  startDate  DateTime         @default(now())
  endDate    DateTime
  paid       Boolean          @default(false)
  paymentId  String?
  autoRenew  Boolean          @default(false)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

enum SubscriptionPlan {
  FREE      // 0₽ — просто в списке
  VIP       // 5000₽/мес — отдельный блок (5 мест)
}

// ── Буст «Огонёк» (500₽ / 7 дней) ─────────────
model Boost {
  id         String   @id @default(cuid())
  serverId   String
  server     Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  startDate  DateTime @default(now())
  endDate    DateTime
  paid       Boolean  @default(false)
  paymentId  String?
  createdAt  DateTime @default(now())

  @@index([serverId, endDate])
  @@index([endDate])
}

// ── Отзывы ────────────────────────────────────
model Review {
  id        String   @id @default(cuid())
  rating    Int      // 1-5
  text      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  serverId  String
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, serverId]) // один отзыв на пользователя на сервер
}

// ── Новости ───────────────────────────────────
model News {
  id        String   @id @default(cuid())
  serverId  String
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  title     String
  body      String
  source    String   @default("manual") // manual | telegram
  date      DateTime @default(now())
}

// ── Логи мониторинга ──────────────────────────
model MonitorLog {
  id        String   @id @default(cuid())
  serverId  String
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  online    Boolean
  ping      Int?     // в миллисекундах
  players   Int?
  checkedAt DateTime @default(now())

  @@index([serverId, checkedAt])
}

// ── Голоса ────────────────────────────────────
model Vote {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  serverId  String
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  ip        String
  nickname  String   @default("")
  createdAt DateTime @default(now())

  @@index([serverId, userId, createdAt])
  @@index([serverId, ip, createdAt])
  @@index([serverId, nickname, createdAt])
}

// ── Заявки на добавление ──────────────────────
model ServerRequest {
  id          String    @id @default(cuid())
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  name        String
  chronicle   String
  rates       String
  url         String
  openedDate  DateTime?                       // когда открылся / откроется
  status      String    @default("pending")   // pending | approved | rejected | pending_payment
  contact     String?                         // TG/VK для связи (для платных «Скоро открытие»)
  paid        Boolean   @default(false)       // true для оплаченных «Скоро открытие»
  paymentId   String?                         // ЮКасса payment id
  ip          String?
  createdAt   DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([paid])
  @@index([paymentId])
}

// ── Рекламные баннеры (продаются вручную через Telegram) ──
// Управляются в админке. На сайте показываются справа сверху с пометкой «Реклама».
model Banner {
  id          String    @id @default(cuid())
  slot        Int       @default(1)              // 1 или 2 — позиция в правом блоке
  title       String                             // заголовок объявления
  subtitle    String?                            // подзаголовок (хроника/рейты/дата)
  image       String?                            // URL загруженной картинки (/uploads/...)
  href        String                             // куда ведёт клик (сайт сервера)
  advertiser  String?                            // рекламодатель (для маркировки 38-ФЗ)
  erid        String?                            // токен ОРД (если уже получен)
  active      Boolean   @default(true)
  endDate     DateTime?                          // до какой даты крутить (null = бессрочно)
  clicks      Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([active, slot])
}

// ── Статьи блога ─────────────────────────────
model Article {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  description String                            // SEO description, 1-2 предложения
  content     String                            // Markdown
  image       String?                           // URL обложки (загружается через /upload?type=banner)
  category    String    @default("Новости")
  serverIds   String[]  @default([])            // ID проектов, к которым привязана статья
  publishedAt DateTime?                         // null = черновик, дата = опубликовано
  views       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([publishedAt])
  @@index([category])
  @@index([slug])
  @@index([serverIds], type: Gin)
}

// ── Гайды (CMS, наполняются через админку) ───
model Guide {
  id          String    @id @default(cuid())
  slug        String    @unique
  chronicle   String                            // 'interlude' | 'high-five' | 'essence' | 'main'
  category    String                            // 'novichkam' | 'kvesty' | 'klassy' | ...
  title       String
  titleEn     String?                           // англ. название (подзаголовок под русским)
  description String    @default("")            // SEO description, 1-2 предложения
  content     String    @default("")            // Markdown
  image       String?                           // URL обложки (1200×630)
  levelMin    Int?                              // диапазон уровней «с»
  levelMax    Int?                              // диапазон уровней «по»
  npc         String?                           // стартовый NPC (для квестов)
  location    String?                           // локация (для квестов/локаций)
  reward      String?                           // награда / краткий итог
  race        String?                           // 'human'|'elf'|... | null = для всех рас
  repeatable  Boolean   @default(false)         // повторяемый квест (∞) или одноразовый
  types       String[]  @default([])            // теги-типы: Сюжетный, Клановые, Повторяемые, ...
  sort        Int       @default(0)             // ручная сортировка внутри категории
  publishedAt DateTime?                         // null = черновик, дата = опубликовано
  views       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([chronicle, category])
  @@index([publishedAt])
  @@index([slug])
}
