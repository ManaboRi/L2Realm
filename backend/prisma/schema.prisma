// ══════════════════════════════════════════════
// L2Realm — Prisma Schema
// База данных: PostgreSQL
// ══════════════════════════════════════════════

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Пользователи ──────────────────────────────
model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  password           String?
  name               String?
  nickname           String?   @unique
  avatar             String?
  role               Role      @default(USER)
  emailVerified      Boolean   @default(false)
  emailCode          String?
  emailCodeExpires   DateTime?
  resetToken         String?
  resetTokenExpires  DateTime?
  registrationIp     String?
  vkId               String?   @unique
  nicknameChangedAt  DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  reviews        Review[]
  favorites      Favorite[]
  serverRequests ServerRequest[]
  votes          Vote[]
}

enum Role {
  USER
  ADMIN
}

// ── Серверы ───────────────────────────────────
model Server {
  id          String   @id
  name        String
  abbr        String?
  url         String
  chronicle   String
  rates       String
  rateNum     Int      @default(1)
  donate      String   @default("cosmetic") // cosmetic | convenience | p2w
  type        String[] // pvp | pve | pvp-pve | gve | rvr | multiproff | multicraft | new | featured
  vip         Boolean  @default(false)
  openedDate  DateTime?
  country     String   @default("RU")
  icon        String?
  banner      String?
  discord     String?
  telegram    String?
  vk          String?
  youtube     String?
  site        String?
  clientUrl   String?
  patchUrl    String?
  updaterUrl  String?
  installGuide String?
  shortDesc   String?
  fullDesc    String?
  rating       Float    @default(0)
  ratingCount  Int      @default(0)
  totalVotes   Int      @default(0)
  monthlyVotes Int      @default(0)
  weeklyVotes  Int      @default(0)
  voteRewardsEnabled Boolean @default(false)
  status      String   @default("online") // online | offline | unknown
  statusOverride String? // null/auto = мониторинг, online/offline/unknown = ручной статус
  // Внутренние «запуски» проекта (Scryde-кейс). Каждый — карточка
  // с рейтом/хроникой/URL внешнего сайта. Без своих ID, отзывов, голосов.
  // [{ id, label?, chronicle, rates, rateNum, type?, donate?, url, openedDate? }]
  instances    Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reviews      Review[]
  subscription Subscription?
  news         News[]
  monitorLogs  MonitorLog[]
  favorites    Favorite[]
  boosts       Boost[]
  votes        Vote[]
}

// ── Избранное / Watchlist ─────────────────────
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  serverId  String
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, serverId])
  @@index([userId])
}

// ── Подписки / Тарифы ─────────────────────────
model Subscription {
  id         String           @id @default(cuid())
  serverId   String           @unique
  server     Server           @relation(fields: [serverId], references: [id], onDelete: Cascade)
  plan       SubscriptionPlan @default(FREE)
  startDate  DateTime         @default(now())
  endDate    DateTime
  paid       Boolean          @default(false)
  paymentId  String?
  autoRenew  Boolean          @default(false)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

enum SubscriptionPlan {
  FREE      // 0₽ — просто в списке
  VIP       // 5000₽/мес — отдельный блок (5 мест)
}

// ── Буст «Огонёк» (500₽ / 7 дней) ─────────────
model Boost {
  id         String   @id @default(cuid())
  serverId   String
  server     Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  startDate  DateTime @default(now())
  endDate    DateTime
  paid       Boolean  @default(false)
  paymentId  String?
  createdAt  DateTime @default(now())

  @@index([serverId, endDate])
  @@index([endDate])
}

// ── Отзывы ────────────────────────────────────
model Review {
  id        String   @id @default(cuid())
  rating    Int      // 1-5
  text      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  serverId  String
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, serverId]) // один отзыв на пользователя на сервер
}

// ── Новости ───────────────────────────────────
model News {
  id        String   @id @default(cuid())
  serverId  String
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  title     String
  body      String
  source    String   @default("manual") // manual | telegram
  date      DateTime @default(now())
}

// ── Логи мониторинга ──────────────────────────
model MonitorLog {
  id        String   @id @default(cuid())
  serverId  String
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  online    Boolean
  ping      Int?     // в миллисекундах
  players   Int?
  checkedAt DateTime @default(now())

  @@index([serverId, checkedAt])
}

// ── Голоса ────────────────────────────────────
model Vote {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  serverId  String
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  ip        String
  nickname  String   @default("")
  createdAt DateTime @default(now())

  @@index([serverId, userId, createdAt])
  @@index([serverId, ip, createdAt])
  @@index([serverId, nickname, createdAt])
}

// ── Заявки на добавление ──────────────────────
model ServerRequest {
  id          String    @id @default(cuid())
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  name        String
  chronicle   String
  rates       String
  url         String
  openedDate  DateTime?                       // когда открылся / откроется
  status      String    @default("pending")   // pending | approved | rejected | pending_payment
  contact     String?                         // TG/VK для связи (для платных «Скоро открытие»)
  paid        Boolean   @default(false)       // true для оплаченных «Скоро открытие»
  paymentId   String?                         // ЮКасса payment id
  ip          String?
  createdAt   DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([paid])
  @@index([paymentId])
}

// ── Статьи блога ─────────────────────────────
model Article {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  description String                            // SEO description, 1-2 предложения
  content     String                            // Markdown
  image       String?                           // URL обложки (загружается через /upload?type=banner)
  category    String    @default("Новости")
  publishedAt DateTime?                         // null = черновик, дата = опубликовано
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([publishedAt])
  @@index([category])
  @@index([slug])
}
