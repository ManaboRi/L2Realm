# ══════════════════════════════════════════════
# L2Realm Backend — .env
# Скопируй в .env и заполни своими значениями
# ══════════════════════════════════════════════

# База данных PostgreSQL
DATABASE_URL="postgresql://l2realm:l2realm_pass@localhost:5432/l2realm"

# JWT секрет — ОБЯЗАТЕЛЬНО смени на длинную случайную строку!
JWT_SECRET="CHANGE_ME_TO_SOMETHING_VERY_LONG_AND_RANDOM"

# URL фронтенда (для CORS)
FRONTEND_URL="http://localhost:3000"

# Порт бекенда
PORT=4000

# ЮКасса (заполни когда получишь доступ)
YOOKASSA_SHOP_ID=""
YOOKASSA_SECRET_KEY=""

# Admin по умолчанию (используется в seed)
ADMIN_EMAIL="admin@l2realm.ru"
ADMIN_PASS="L2Realm_Admin_2026"
